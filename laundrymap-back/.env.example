###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=                         # générer avec : openssl rand -hex 32
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:root@mariadb:3306/laundrymap?serverVersion=mariadb-11.0.0"
DB_NAME=laundrymap
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null              # ex: smtp://user:pass@smtp.mailtrap.io:2525
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=                     # générer avec : openssl rand -hex 32
# Générer les clés avec : php bin/console lexik:jwt:generate-keypair
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=http://localhost:8888
###< nelmio/cors-bundle ###

###> cookie security ###
COOKIE_SECURE=false                 # true en production (HTTPS)
###< cookie security ###

# Total de signalements cumulés sur les commentaires d'un utilisateur avant qu'il
# n'apparaisse comme à examiner pour bannissement dans la modération utilisateurs (RG-211)
SIGNALEMENT_SEUIL_BANNISSEMENT=15

###> wi-line/api ###
WILINE_USERNAME=
WILINE_API_KEY=
###< wi-line/api ###

###> google/apiclient ###
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_CONFIG=%kernel.project_dir%/path/to/file.json
###< google/apiclient ###

###> fichiers publics frontend ###
FRONTEND_PUBLIC_DIR=/frontend-public
###< fichiers publics frontend ###

###> frontend url ###
FRONTEND_URL=http://localhost:8888  # URL publique du frontend (utilisée dans les emails)
###< frontend url ###
