# Copier ce fichier en deploy-secrets.sh sur le serveur (jamais commité)
# cp deploy-secrets.sh.example deploy-secrets.sh
# Puis remplir les valeurs réelles ci-dessous

SMOKE_TEST_ADMIN_EMAIL="admin@votre-domaine.com"
SMOKE_TEST_ADMIN_PASSWORD="votre-mot-de-passe-admin"

# ID d'une laverie de fixtures stable en prod (avec une adresse connue)
SMOKE_TEST_LAVERIE_ID="1"
SMOKE_TEST_LAVERIE_ADRESSE="12 rue de la Paix"
SMOKE_TEST_LAVERIE_CP="75001"
SMOKE_TEST_LAVERIE_VILLE="Paris"

# ──────────────────────────────────────────────────────────────────────────────
# Variables REQUISES dans laundrymap-back/.env.local sur le serveur de prod
# (ne pas copier ici — les mettre directement dans .env.local)
# ──────────────────────────────────────────────────────────────────────────────
# APP_ENV=prod
# APP_SECRET=<openssl rand -hex 32>
# DATABASE_URL="mysql://user:pass@127.0.0.1:3306/laundrymap?serverVersion=mariadb-11.0.0"
# COOKIE_SECURE=true
# CORS_ALLOW_ORIGIN=https://groupe-1.lycee-stvincent.net
# JWT_PASSPHRASE=<doit correspondre aux clés PEM dans config/jwt/>
# MAILER_DSN=smtp://...
# WILINE_USERNAME=...
# WILINE_API_KEY=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
